@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using Umbraco.Extensions
@using TestProject.Interfaces
@using TestProject.Models
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ExternalNewsPage>
@inject INewsFeedService NewsFeedService
@{
    Layout = "master.cshtml";

    var feedUrl = Model.SourceUrl;
    var items = await NewsFeedService.GetFeedItemsAsync(feedUrl ?? string.Empty);
}

@Html.Partial("~/Views/Partials/SectionHeader.cshtml")

<section class="section">

  <div class="container">
    <div class="col-md-12">
      <article>
        @await Html.GetBlockGridHtmlAsync(Model, "bodyText")
      </article>
      <div class="news-container">

        @foreach (var item in items)
        {
            var description = item.Description.Length > 100
                ? item.Description[..100] + "..."
                : item.Description;
            var day = item.PublishDate.Day;
            var suffix = day switch
            {
                1 or 21 or 31 => "st",
                2 or 22 => "nd",
                3 or 23 => "rd",
                _ => "th"
            };
            var formattedDate = $"{day}{suffix} {item.PublishDate:MMMM yyyy}";
        <article class="news-item">
          @if (!string.IsNullOrEmpty(item.ImageUrl))
          {
          <img src="@item.ImageUrl" alt="@item.Title">
          }
          <div class="news-content">
            <h2>@item.Title</h2>
            <p class="date">@formattedDate</p>
            <p>@description</p>
            <a href="@item.Link" class="read-more" target="_blank" rel="noopener noreferrer">read more</a>
          </div>
        </article>
        }

      </div>
    </div>
  </div>

</section>

<link rel="stylesheet" href="@Url.Content("~/css/umbraco-starterkit-blockgrid.css")" />
<link rel="stylesheet" href="@Url.Content("~/css/newslist.css")" />